PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/jobhuntr
JWT_SECRET=replace_with_a_strong_secret
CLIENT_URL=http://localhost:5173
APP_NAME=JobHuntr

# SMTP config for transactional emails (password reset, verification, 2FA, team invites)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=JobHuntr

# Optional alternative to SMTP_HOST/SMTP_PORT/... above
# SMTP_URL=smtps://username:password@smtp.example.com:465
